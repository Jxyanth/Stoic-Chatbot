import streamlit as st
from stoic_rag_chatbot import ask_stoic_bot # Import your working function

# --- UI Configuration ---
st.set_page_config(page_title="Stoic Wisdom AI", page_icon="🏛️", layout="centered")

# Custom CSS to make it look cleaner
st.markdown("""
    <style>
    .stApp { background-color: #131314; color: #e3e3e3; }
    .stChatInputContainer { padding-bottom: 20px; }
    </style>
    """, unsafe_allow_html=True)

st.title("🏛️ Stoic Wisdom AI")
st.caption("Guided by the teachings of Marcus Aurelius, Seneca, and Epictetus.")

# --- Sidebar for Settings ---
with st.sidebar:
    st.header("Settings")
    st.info("This bot uses a local Qdrant database and OpenRouter (Gemini 2.0 Flash Lite) to provide Stoic guidance.")
    if st.button("Clear Chat History"):
        st.session_state.messages = []

# --- Chat History Logic ---
if "messages" not in st.session_state:
    st.session_state.messages = []

# Display existing messages
for message in st.session_state.messages:
    with st.chat_message(message["role"]):
        st.markdown(message["content"])

# --- User Input ---
if prompt := st.chat_input("Ask for Stoic advice..."):
    # Add user message to history
    st.session_state.messages.append({"role": "user", "content": prompt})
    with st.chat_message("user"):
        st.markdown(prompt)

    # Generate response
    with st.chat_message("assistant"):
        with st.spinner("The masters are reflecting..."):
            try:
                # Call your RAG function
                response = ask_stoic_bot(prompt)
                st.markdown(response)
                # Add assistant response to history
                st.session_state.messages.append({"role": "assistant", "content": response})
            except Exception as e:
                st.error(f"Error: {e}")